# Copy this to .env.local and fill in your values
# Get these from: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The email address of the admin account (must be registered in Supabase Auth)
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourschool.edu.ng

# Supabase service role key (for admin operations — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Random string used to sign student session cookies (generate a long random string)
SESSION_SECRET=your-session-secret-here

# Resend API (for sending OTP emails)
# Get these from: https://resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_DOMAIN=your-domain.com
